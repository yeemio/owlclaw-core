{
  "name": "owlclaw-console-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:console": "npm run generate:types:mock && npm run build",
    "generate:types": "openapi-typescript http://localhost:8000/api/v1/openapi.json -o src/api/types.ts",
    "generate:types:mock": "openapi-typescript ./openapi.mock.json -o src/api/types.ts",
    "lint": "eslint .",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "server": "cd ../../.. && poetry run owlclaw start --port 8000",
    "test:e2e:run": "playwright test e2e/console-flow.spec.ts",
    "test:e2e": "start-server-and-test server http://127.0.0.1:8000/healthz test:e2e:run",
    "test:e2e:manual": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.5.6",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
